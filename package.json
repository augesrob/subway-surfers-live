{
  "name": "subway-surfers-live",
  "version": "1.0.0",
  "description": "Subway Surfers with TikTok Live integration",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-packager . \"Subway Surfers LIVE\" --platform=win32 --arch=x64 --electron-version=28.0.0 --out=dist --overwrite --ignore=\"^/dist\" --ignore=\"node_modules/.cache\" --ignore=\"^/.github\"",
    "build": "electron-builder --win --x64"
  },
  "devDependencies": {
    "electron": "28.0.0",
    "@electron/packager": "^20.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.streamvibe.subwaysurferslive",
    "productName": "Subway Surfers LIVE",
    "copyright": "StreamVibe",
    "directories": { "output": "dist" },
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico"
    },
    "files": [
      "**/*",
      "!dist/**",
      "!node_modules/.cache/**",
      "!**/*.map",
      "!.github/**"
    ],
    "publish": null
  }
}
